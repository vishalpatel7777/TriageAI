generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Ticket {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  message         String
  category        String
  priority        String
  summary         String
  suggestedAction String
  needsHuman      Boolean
  confidence      Float
  createdAt       DateTime @default(now())
}